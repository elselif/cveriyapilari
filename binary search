#include <stdio.h>
#include <stdlib.h>
/*
ARAMA ALGORİTMASI

1-linear search
2-binary search 

*/

bool binarySearch(int dizi[],int bas,int son,int aranan){
	while(son>=bas){
		int orta=dizi[(bas+son)/2];
		if(orta == aranan){
			return true;
		}
		if(orta<aranan)
			bas++;
			if(orta>aranan)
				son--;
		
		
	}
	return false;
}


int main(){

	int n;
	printf("dizi boyunu giriniz : ");
	scanf("%d",&n);
	int dizi[n];
	
	int i=0;
	while(i<n)
	{
		printf("sayi girin :");
		scanf("%d",&dizi[i]);
		i++;
	}
	printf("aradıgınız sayiyi girin : \n");
	int aranan;
	scanf("%d",&aranan);
	
	bool sonuc = binarySearch(dizi,0,n-1,aranan);
	if(sonuc)
	printf("aranan sayi dizide vardir");
	else
	printf("aranan sayi dizide yoktur");

return 0;
}
